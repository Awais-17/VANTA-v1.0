# ==============================================================================
# VANTA — Governance Intelligence Platform Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AI CONFIGURATION (Gemini API for complaint categorization & priority scaling)
# ------------------------------------------------------------------------------
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Recommended model for high speed & low latency
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (MongoDB connection string)
# ------------------------------------------------------------------------------
# Local MongoDB connection (Default)
DATABASE_URL=mongodb://localhost:27017/h2k
MONGODB_URI=mongodb://localhost:27017/h2k

# MongoDB Atlas (Cloud deployment example)
# DATABASE_URL=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/vanta?retryWrites=true&w=majority

# ------------------------------------------------------------------------------
# 3. APP & SECURITY CONFIGURATION
# ------------------------------------------------------------------------------
# Secret key used for signing JWT access tokens (Make it long & random in production!)
SECRET_KEY=vanta-jwt-hackathon-super-secret-key-1337

# Set to "production" in deployed environments to enforce strict CORS & optimizations
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# 4. DEPLOYMENT PORT (Required by some cloud providers)
# ------------------------------------------------------------------------------
PORT=8000
